{
  "coverageDirectory": "../coverage",
  "moduleFileExtensions": ["js", "jsx", "ts", "tsx", "json"],
  "preset": "ts-jest/presets/default-esm",
  "rootDir": "src",
  "testMatch": ["**/*.spec.ts"],
  "verbose": true,
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.(ts|tsx)$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": { "module": "ESNext", "moduleResolution": "Bundler", "isolatedModules": true }
      }
    ]
  }
}
